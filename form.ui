         <property name="styleSheet">
          <string notr="true"/>
         </property>
         <property name="text">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Phần mềm hỗ trợ xử lý toàn bộ đơn hàng từ nhiều hệ thống:&lt;/p&gt;&lt;p&gt;• MT (Modern Trade): Big C / GO!, Lotte Mart, Satra, Kingfood, Winmart, Fujimart, …&lt;/p&gt;&lt;p&gt;• TMĐT (E-commerce): Shopee, TikTok Shop, …&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
         </property>
        </widget>
       </widget>
